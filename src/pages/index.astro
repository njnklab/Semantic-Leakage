---
const normalizedBaseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

// Dataset metadata
const datasetMeta: Record<string, { 
  key: string; 
  label: string; 
  language: string; 
  sample: number; 
  duration: string;
  type: string;
  description: string;
  depressionMetric: string;
} > = {
  edaic: { 
    key: 'edaic', 
    label: 'E-DAIC', 
    language: 'English', 
    sample: 189, 
    duration: '~20 min',
    type: 'Fixed-script distress interview',
    description: 'Extended Distress Analysis Interview Corpus for AVEC 2019, derived from DAIC-WOZ and annotated with PHQ-8 scores.',
    depressionMetric: 'PHQ-8'
  },
  pdch: { 
    key: 'pdch', 
    label: 'PDCH', 
    language: 'Chinese', 
    sample: 100, 
    duration: '~30 min',
    type: 'Clinical consultation',
    description: 'Parallel Data of Depression Consultation and HAMD-17: 100 real-world psychiatrist-inpatient consultations totaling more than 2,937 minutes.',
    depressionMetric: 'HAMD-17'
  },
  cmdc: { 
    key: 'cmdc', 
    label: 'CMDC', 
    language: 'Chinese', 
    sample: 78, 
    duration: 'Variable',
    type: 'Semi-structured interview',
    description: 'Chinese Multimodal Depression Corpus, a Mandarin semi-structured interview dataset with 26 depressed participants and 52 healthy controls.',
    depressionMetric: 'Clinical diagnosis'
  },
  mandic: { 
    key: 'mandic', 
    label: 'ManDIC', 
    language: 'Chinese', 
    sample: 557, 
    duration: '143.56 h',
    type: 'Clinical interview',
    description: 'Mandarin Distress Interview Corpus collected in a real clinical environment at Nanjing Brain Hospital; mean recording length is 927.85 seconds.',
    depressionMetric: 'HAMD-17'
  }
};

const manuscriptPdfUrl = `${normalizedBaseUrl}pdfs/semantic-leakage.pdf`;
const analysisRepoUrl = 'https://github.com/njnklab/Semantic-Leakage';

// Color scheme for datasets
const datasetColorMap: Record<string, string> = {
  edaic: '#CC79A7',
  pdch: '#E69F00',
  cmdc: '#56B4E9',
  mandic: '#009E73'
};

// Key findings data
const keyFindings = [
  {
    id: 1,
    title: 'Cue Spans Are Clinically Anchored',
    description: 'Verified cue spans concentrate on depressive symptom content, show stronger negative semantics than surrounding transcript, and align with DSM-5 symptom domains across languages.',
    metric: 'DSM-5 match: 72.2%, 83.3%, 92.2%, 72.7%',
    dataset: 'E-DAIC, PDCH, CMDC, ManDIC'
  },
  {
    id: 2,
    title: 'Leakage Is Widespread but Heterogeneous',
    description: 'Cue-only audio often remains predictive, while cue-excluded audio increases MAE more than duration-matched random exclusion. The effect varies by conversational setting and backbone.',
    metric: 'PDCH DMPF: 6.787 -> 8.720 MAE after cue exclusion',
    dataset: 'Cross-dataset audit'
  },
  {
    id: 3,
    title: 'Patient Disclosure Drives the Shortcut',
    description: 'Role-specific experiments show that patient-produced cue spans explain most of the cue-specific degradation, whereas interviewer prompts have smaller effects after random-duration control.',
    metric: 'All-cue Δdiff: 0.130, 0.329, 0.314, 0.338',
    dataset: 'Dialogue-speech view'
  },
  {
    id: 4,
    title: 'CueFilter Reduces Shortcut Reliance',
    description: 'CueFilter softly suppresses cue-dominated acoustic regions without transcripts at inference, lowering cue-minus-random sensitivity while preserving the downstream prediction pipeline.',
    metric: 'Shortcut-gap reduction: 54% to 67%',
    dataset: 'Within-dataset mitigation'
  }
];

// Method steps
const methodSteps = [
  {
    step: 1,
    title: 'Preprocess and Diarize',
    description: 'Resample audio, normalize speaker loudness, apply pre-emphasis, and preserve pauses and low-energy intervals while diarization partitions speaker-homogeneous segments.'
  },
  {
    step: 2,
    title: 'Multi-ASR Reconciliation',
    description: 'Run diversified ASR decoding passes, align candidate segments by time, select high-confidence hypotheses, and use local LLM refinement when hypotheses disagree.'
  },
  {
    step: 3,
    title: 'Speaker Role Attribution',
    description: 'Assign interviewer or participant roles from sliding dialogue context, then enforce local consistency with diarization to isolate patient-produced speech.'
  },
  {
    step: 4,
    title: 'Hierarchical Cue Detection',
    description: 'Detect symptom-category candidates with English and Mandarin lexicons, expand phrases, verify clinical relevance, resolve short question-answer cues, and manually review final spans.'
  },
  {
    step: 5,
    title: 'Controlled Reconstruction',
    description: 'Construct preprocessed, cue-only, cue-excluded, and duration-matched random-control views so performance changes can be attributed to semantic cue content rather than waveform length.'
  }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Semantic Leakage in Speech-based Depression Prediction — Paper Website</title>
  <meta name="description" content="Paper website for the manuscript: Semantic Leakage in Speech-based Depression Prediction" />
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500&display=swap');

    :root {
      --bg: #f8fbff;
      --card: #ffffff;
      --accent: #1e40af;
      --text: #0f172a;
      --muted: #1f2937;
      --border: #c8d8ee;
      --border-soft: #d9e5f4;
      --footer-bg: #f0f6ff;
      --radius: 10px;
      --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 8px 24px rgba(15, 23, 42, 0.06);
      --shadow-md: 0 12px 34px rgba(15, 23, 42, 0.10);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-weight: 400;
      line-height: 1.72;
      font-size: 17px;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 { font-family: 'DM Serif Display', serif; font-weight: 400; line-height: 1.2; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; }

    .wrap { width: min(1080px, calc(100vw - 48px)); margin: 0 auto; }
    .mt36 { margin-top: 36px; }
    .sec-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sec-title { font-size: clamp(1.6rem, 3.2vw, 2.4rem); margin-bottom: 12px; }
    .sec-sub { color: var(--muted); font-size: clamp(0.98rem, 1.08vw, 1.1rem); max-width: 60ch; line-height: 1.72; }

    /* ── Nav ── */
    .site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.92); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid var(--border-soft); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; }
    .nav-brand { display: flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 500; font-size: 0.88rem; }
    .nav-mark { width: 30px; height: 30px; border-radius: 7px; background: var(--accent); display: grid; place-items: center; font-weight: 500; font-size: 0.68rem; color: #fff; flex-shrink: 0; }
    .nav-links { display: flex; gap: 4px; }
    .nav-link { padding: 6px 12px; border-radius: 6px; color: var(--muted); font-size: 0.86rem; font-weight: 400; transition: all 0.2s; text-decoration: none; }
    .nav-link:hover, .nav-link.active { color: var(--text); background: rgba(29,78,216,0.09); text-decoration: none; }
    .nav-link.active { color: var(--accent); }

    /* ── Hero ── */
    .hero { min-height: 88vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: clamp(86px, 8vw, 118px) 24px 88px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 140%; background: radial-gradient(ellipse at 50% 30%, rgba(29,78,216,0.08) 0%, transparent 60%); pointer-events: none; }
    .hero-overline { font-size: 0.76rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 22px; line-height: 1.5; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
    .hero-title { font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.1; margin-bottom: 22px; opacity: 0; animation: fadeUp 0.8s 0.4s forwards; }
    .hero-title .amber { color: var(--accent); }
    .hero-sub { font-size: clamp(1rem, 1.2vw, 1.12rem); color: var(--muted); max-width: 64ch; margin-bottom: 26px; line-height: 1.72; opacity: 0; animation: fadeUp 0.8s 0.6s forwards; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
    .hero-cta { display: inline-flex; align-items: center; justify-content: center; padding: 9px 16px; border: 1px solid var(--border-soft); border-radius: 999px; color: var(--text); font-size: 0.84rem; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; background: rgba(255,255,255,0.72); transition: border-color 0.2s, transform 0.2s, background 0.2s; }
    .hero-cta:hover { text-decoration: none; border-color: var(--accent); background: #fff; transform: translateY(-1px); }
    .hero-cta-icon { width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center; margin-right: 8px; color: var(--accent); flex-shrink: 0; }
    .hero-cta-icon svg { width: 100%; height: 100%; display: block; }
    .hero-stats { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: clamp(14px, 3vw, 32px); width: min(760px, 100%); margin-bottom: 24px; opacity: 0; animation: fadeUp 0.8s 0.8s forwards; }
    .h-stat { text-align: center; }
    .h-stat-num { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1.1; }
    .h-stat-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-top: 6px; }
    .hero-domains { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s 1.0s forwards; }
    .hdot { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; color: var(--muted); padding: 5px 10px; border: 1px solid var(--border-soft); border-radius: 999px; background: rgba(255,255,255,0.68); }
    .hdot i { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .hero-visual { width: min(760px, 100%); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-soft); background: var(--card); box-shadow: var(--shadow-md); opacity: 0; animation: fadeUp 0.8s 1.1s forwards; }
    .hero-visual img { width: 100%; display: block; }
    .hero-visual .fig-cap { border-top: 1px solid var(--border-soft); text-align: left; }
    .scroll-arrow { position: absolute; bottom: 22px; left: 50%; transform: translateX(-50%); opacity: 0; animation: fadeUp 0.8s 1.2s forwards; display: inline-flex; flex-direction: column; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; }
    .scroll-arrow small { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); opacity: 0.9; }
    .scroll-arrow i { display: block; width: 1px; height: 10px; background: var(--border-soft); }
    .scroll-arrow span { display: block; width: 14px; height: 14px; border-right: 2px solid var(--muted); border-bottom: 2px solid var(--muted); transform: rotate(45deg); animation: bounce 1.8s infinite; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%,100% { transform: rotate(45deg) translateY(0); } 50% { transform: rotate(45deg) translateY(8px); } }

    /* ── Cards ── */
    .s-card { background: var(--card); border: 1px solid var(--border-soft); border-left: 3px solid var(--accent); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); position: relative; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; box-shadow: var(--shadow-sm); height: 100%; }
    .s-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .s-card-num { position: absolute; top: -8px; right: 12px; font-family: 'DM Serif Display', serif; font-size: 4rem; color: var(--accent); opacity: 0.07; line-height: 1; pointer-events: none; }
    .s-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 8px; }
    .s-card p { font-size: clamp(0.86rem, 0.92vw, 0.94rem); color: var(--muted); line-height: 1.65; }

    /* ── Grid layouts ── */
    .g2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .g3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
    .g4 { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
    .g12 { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 32px); align-items: start; }

    /* ── Sections ── */
    .sec { padding: clamp(62px, 8vw, 96px) 0; scroll-margin-top: 72px; }

    /* ── Figures ── */
    .fig-wrap { border-radius: var(--radius); overflow-x: auto; border: 1px solid var(--border-soft); background: var(--card); box-shadow: var(--shadow-sm); }
    .fig-wrap img { width: 100%; display: block; }
    .fig-cap { padding: 10px 14px; font-size: 0.82rem; color: var(--muted); border-top: 1px solid var(--border-soft); line-height: 1.5; background: #fbfdff; }
    .figure-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .figure-card { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-soft); background: var(--card); box-shadow: var(--shadow-sm); }
    .figure-card img { width: 100%; display: block; }
    .figure-card.span2 { grid-column: 1 / -1; }
    .metric-strip { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-top: 36px; }
    .metric-tile { background: var(--card); border: 1px solid var(--border-soft); border-radius: var(--radius); padding: clamp(16px, 2vw, 22px); box-shadow: var(--shadow-sm); }
    .metric-value { font-family: 'DM Serif Display', serif; font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1; color: var(--accent); margin-bottom: 8px; }
    .metric-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 10px; }
    .metric-tile p { font-size: 0.86rem; color: var(--muted); line-height: 1.55; margin: 0; }

    /* ── Dataset Explorer ── */
    .dataset-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin: 36px 0 0; }
    .dataset-card { background: var(--card); border: 1px solid var(--border-soft); border-radius: var(--radius); padding: clamp(16px, 2vw, 22px); cursor: pointer; transition: all 0.3s; border-top: 3px solid transparent; box-shadow: var(--shadow-sm); height: 100%; }
    .dataset-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .dataset-card.active { border-top-color: var(--accent); box-shadow: 0 4px 20px rgba(29,78,216,0.15); }
    .dataset-card h4 { font-size: clamp(1rem, 1.1vw, 1.15rem); margin-bottom: 6px; }
    .dataset-meta { font-size: 0.76rem; color: var(--muted); margin-bottom: 10px; }
    .dataset-badge { display: inline-block; font-size: 0.68rem; padding: 3px 8px; border-radius: 999px; background: rgba(29,78,216,0.08); color: var(--muted); margin-right: 4px; }
    .dataset-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.55; margin: 0; }

    /* ── Key Findings ── */
    .finding-card { background: var(--card); border: 1px solid var(--border-soft); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 24px); transition: transform 0.3s, box-shadow 0.3s; box-shadow: var(--shadow-sm); height: 100%; }
    .finding-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .finding-num { font-family: 'DM Serif Display', serif; font-size: 2.5rem; color: var(--accent); opacity: 0.15; line-height: 1; margin-bottom: 8px; }
    .finding-card h4 { font-size: clamp(0.95rem, 1.05vw, 1.1rem); margin-bottom: 8px; }
    .finding-card p { font-size: 0.86rem; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
    .finding-metric { font-size: 0.78rem; color: var(--accent); font-weight: 500; }

    /* ── Methods ── */
    .pipeline-horizontal-wrap { overflow-x: auto; padding: 2px 2px 8px; }
    .pipeline-horizontal { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 14px; align-items: stretch; }
    .pipe-h-item { border: 1px solid var(--border-soft); border-radius: var(--radius); background: var(--card); padding: 14px 14px 12px; position: relative; box-shadow: var(--shadow-sm); }
    .pipe-h-item:not(:last-child)::after { content: '→'; position: absolute; right: -10px; top: 22px; font-size: 18px; color: #94a3b8; z-index: 2; }
    .pipe-h-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .pipe-num { width: 26px; height: 26px; border-radius: 50%; background: var(--accent); display: grid; place-items: center; font-size: 0.68rem; font-weight: 500; color: var(--bg); flex-shrink: 0; }
    .pipe-h-item h5 { font-size: 0.86rem; font-weight: 500; color: var(--text); margin: 0; line-height: 1.35; }
    .pipe-h-item p { font-size: 0.8rem; color: var(--muted); line-height: 1.52; margin: 0; }

    /* ── Results Table ── */
    .results-table { width: 100%; min-width: 760px; border-collapse: collapse; font-size: 0.84rem; }
    .results-table th, .results-table td { padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--border-soft); }
    .results-table th { background: #f7fbff; font-weight: 500; color: var(--text); white-space: nowrap; }
    .results-table td { color: var(--muted); }
    .results-table .delta { color: #dc2626; font-weight: 500; }

    /* ── Significance ── */
    .sig-card { background: var(--card); border: 1px solid var(--border-soft); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); border-top: 3px solid var(--accent); transition: transform 0.3s, box-shadow 0.3s; box-shadow: var(--shadow-sm); height: 100%; }
    .sig-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .sig-cat { font-size: 0.68rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sig-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 10px; }
    .sig-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    /* ── Glossary ── */
    .gloss-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1px; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-soft); box-shadow: var(--shadow-sm); background: var(--border-soft); }
    .gloss-item { padding: clamp(14px, 2vw, 20px); background: var(--card); }
    .gloss-term { font-family: 'DM Serif Display', serif; font-weight: 700; font-size: clamp(0.86rem, 0.96vw, 0.95rem); margin-bottom: 8px; }
    .gloss-item p { color: var(--muted); font-size: clamp(0.78rem, 0.86vw, 0.86rem); margin-bottom: 0; line-height: 1.6; }

    /* ── Footer ── */
    .site-footer { background: var(--footer-bg); padding: clamp(48px, 6vw, 80px) 0 40px; border-top: 1px solid var(--border-soft); }
    .footer-label { font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); margin-bottom: 20px; }
    .res-btn { display: flex; align-items: center; gap: 12px; padding: 16px 24px; border: 1px solid var(--border-soft); border-radius: var(--radius); color: var(--text); text-decoration: none; font-size: 0.9rem; flex: 1; min-width: 180px; transition: all 0.25s; background: var(--card); box-shadow: var(--shadow-sm); }
    .res-btn:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
    .res-btn-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(29,78,216,0.1); display: grid; place-items: center; font-size: 0.7rem; font-weight: 500; color: var(--accent); flex-shrink: 0; }
    .res-btn-text span { display: block; font-size: 0.84rem; color: var(--muted); }
    .citation { font-size: 0.84rem; color: var(--muted); line-height: 1.6; border-top: 1px solid var(--border-soft); padding-top: 24px; max-width: 60ch; font-family: 'IBM Plex Sans', monospace; }

    /* ── Scroll reveal ── */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .stagger > * { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(2) { transition-delay: 0.08s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(3) { transition-delay: 0.12s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(4) { transition-delay: 0.18s; opacity: 1; transform: none; }

    /* ── Responsive ── */
    @media (max-width: 1100px) {
      .dataset-grid, .metric-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .pipeline-horizontal { min-width: 1040px; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { min-height: auto; padding: 82px 16px 70px; }
      .hero-overline { font-size: 0.68rem; letter-spacing: 0.14em; max-width: 38ch; }
      .hero-title { font-size: clamp(2rem, 12vw, 2.8rem); }
      .hero-sub { font-size: 0.98rem; line-height: 1.65; }
      .hero-ctas { gap: 8px; }
      .hero-cta { width: 100%; max-width: 320px; }
      .hero-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px 12px; }
      .h-stat-label { font-size: 0.68rem; letter-spacing: 0.08em; }
      .hero-domains { gap: 7px; margin-bottom: 22px; }
      .hdot { font-size: 0.76rem; padding: 4px 9px; }
      .g2, .g12 { grid-template-columns: 1fr; }
      .g3, .g4 { grid-template-columns: 1fr; }
      .dataset-grid { grid-template-columns: 1fr; }
